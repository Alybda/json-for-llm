{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "0.0.1",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
